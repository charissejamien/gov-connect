@page "/notfound"

<PageTitle>Page Not Found | GovConnect</PageTitle>
<div class="system-state-page">
    <div class="system-state-code">404</div>
    <p class="section-label">Page Not Found</p>
    <h1>We could not locate that service.</h1>
    <p>The page may have moved, or the address may be incorrect. Return to your dashboard to continue using GovConnect.</p>
    <NavLink href="/user/dashboard" class="system-state-action">Return to dashboard</NavLink>
</div>
