@page "/admin/dashboard"
@inject Supabase.Client SupabaseClient
@inject NavigationManager Navigation
@using gov_connect.Data.Models
@using gov_connect.Components.Shared

<div class="admin-page flex flex-col gap-10 xl:w-[80%] xl:mx-auto p-6 md:p-10 font-sans">
    <RequestReviewModal IsOpen="showReviewModal" Request="selectedRequest" OnClose="CloseReviewModal" />

    <div class="rounded-xl overflow-hidden text-white relative shadow-md">
        <div class="absolute inset-0 z-0 bg-cover bg-no-repeat bg-center"
             style="background-image: url('icons/container.svg');">
        </div>

        <div class="relative z-10 p-10 flex flex-col gap-5">
            <h1 class="text-[28px] font-bold">Magandang Araw, Admin!</h1>
            <p class="max-w-xl text-white/90 font-medium">
                Welcome back to the GovConnect Operations Portal. Monitor incoming transactions,
                validate user identities, and approve document requests instantly.
            </p>
            <div class="flex flex-wrap gap-5 mt-2">
                <button @onclick="NavigateToManageRequests"
                        class="bg-[#276FC2] hover:bg-[#1f5da3] transition-colors rounded-xl p-3 flex gap-2 items-center text-sm font-semibold">
                    <img src="icons/search.svg" alt="" class="h-5">
                    View All Requests
                </button>
                <button
                    class="bg-[#D89843] hover:bg-[#bd8339] transition-colors rounded-xl p-3 flex gap-2 items-center text-sm font-semibold">
                    <img src="icons/add.svg" alt="" class="h-5">
                    Register New Agency
                </button>
            </div>
        </div>
    </div>

    <!-- Analytics Stats -->
    <div class="w-full grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-[#FFE0B2] border border-[#FFE2BC] rounded-xl p-5 pb-7 w-full shadow-sm text-gray-800">
            <div class="flex justify-between items-start">
                <p class="text-[12px] font-bold text-amber-800 uppercase tracking-wider">Pending Review</p>
                <img src="icons/total-requests.svg" alt="" class="w-8 h-8">
            </div>
            <h2 class="font-bold text-[32px] mt-2 text-amber-900">@pendingCount</h2>
        </div>

        <div class="bg-[#D1C4E9] border border-[#D1D4E9] rounded-xl p-5 pb-7 w-full shadow-sm text-gray-800">
            <div class="flex justify-between items-start">
                <p class="text-[12px] font-bold text-purple-800 uppercase tracking-wider">Processing</p>
                <img src="icons/in-progress.svg" alt="" class="w-8 h-8">
            </div>
            <h2 class="font-bold text-[32px] mt-2 text-purple-900">@processingCount</h2>
        </div>

        <div class="bg-[#C8E6C9] border border-[#C8E8D9] rounded-xl p-5 pb-7 w-full shadow-sm text-gray-800">
            <div class="flex justify-between items-start">
                <p class="text-[12px] font-bold text-green-800 uppercase tracking-wider">Ready for Pickup</p>
                <img src="icons/for-pickup.svg" alt="" class="w-8 h-8">
            </div>
            <h2 class="font-bold text-[32px] mt-2 text-green-900">@readyCount</h2>
        </div>

        <div class="bg-[#B3E5FC] border border-[#B3EBFD] rounded-xl p-5 pb-7 w-full shadow-sm text-gray-800">
            <div class="flex justify-between items-start">
                <p class="text-[12px] font-bold text-blue-800 uppercase tracking-wider">Completed Overall</p>
                <img src="icons/total-requests.svg" alt="" class="w-8 h-8">
            </div>
            <h2 class="font-bold text-[32px] mt-2 text-blue-900">@completedCount</h2>
        </div>
    </div>

    <!-- Active Table Queue -->
    <div>
        <div class="flex justify-between items-center mb-5">
            <h3 class="text-[28px] font-bold text-slate-800">High-Priority Queue</h3>
            <span class="text-xs font-bold text-gray-500 uppercase">Live Updates</span>
        </div>

        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr
                        class="bg-slate-50 border-b border-slate-200 text-slate-600 text-xs font-bold uppercase tracking-wider">
                        <th class="p-4 pl-6">Tracking ID</th>
                        <th class="p-4">Applicant</th>
                        <th class="p-4">Document Type</th>
                        <th class="p-4">Method</th>
                        <th class="p-4">Status</th>
                        <th class="p-4 pr-6 text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm text-slate-700">
                    @if (allRequests.Any())
                    {
                        @foreach (var request in allRequests)
                        {
                            <tr class="hover:bg-slate-50/50 transition-colors">
                                <td class="p-4 pl-6 font-mono font-semibold text-xs text-blue-600">#@request.Id</td>
                                <td class="p-4">
                                    <div class="font-semibold text-slate-900">@request.FirstName @request.LastName</div>
                                    <div class="text-[11px] text-gray-400">@request.Purpose</div>
                                </td>
                                <td class="p-4">
                                    <span class="font-medium text-slate-800">@request.DocumentTitle</span>
                                    <span class="block text-[11px] text-gray-400">@request.DocumentAgency</span>
                                </td>
                                <td class="p-4">
                                    <span
                                        class="px-2 py-1 rounded text-xs font-semibold @(request.DeliveryMethod == "Delivery" ? "bg-amber-100 text-amber-800" : "bg-sky-100 text-sky-800")">
                                        @request.DeliveryMethod
                                    </span>
                                </td>
                                <td class="p-4">
                                    <span
                                        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-bold @GetStatusBadgeClass(request.Status)">
                                        <span class="w-1.5 h-1.5 rounded-full @GetStatusDotClass(request.Status)"></span>
                                        @request.Status
                                    </span>
                                </td>
                                <td class="p-4 pr-6 text-right">
                                    <button @onclick="() => OpenReviewModal(request)"
                                            class="bg-[#276FC2] hover:bg-[#A8C7FA] hover:text-[#002D62] text-white font-semibold py-1.5 px-3 rounded-lg text-xs transition-colors duration-150">
                                        Review
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-12 text-gray-500">
                                No active requests in database. Good job!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private int pendingCount = 0;
    private int processingCount = 0;
    private int readyCount = 0;
    private int completedCount = 0;
    private bool showReviewModal = false;
    private RequestItem? selectedRequest;
    private List<RequestItem> allRequests = new();

    protected override async Task OnInitializedAsync()
    {
        var user = SupabaseClient.Auth.CurrentUser;

        if (user == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        bool isAdmin = false;
        if (user.UserMetadata != null && user.UserMetadata.TryGetValue("role", out var roleObj))
        {
            isAdmin = roleObj?.ToString() == "admin";
        }

        if (!isAdmin)
        {
            Navigation.NavigateTo("/user/dashboard");
            return;
        }
        s
                await RefreshData();
    }

    private async Task RefreshData()
    {
        try
        {
            var response = await SupabaseClient.From<RequestItem>()
                .Order("created_at", Supabase.Postgrest.Constants.Ordering.Descending)
                .Get();

            allRequests = response.Models ?? new List<RequestItem>();

            pendingCount = allRequests.Count(r => r.Status == "Pending");
            processingCount = allRequests.Count(r => r.Status == "In Progress" || r.Status == "Processing");
            readyCount = allRequests.Count(r => r.Status == "Ready for Pickup");
            completedCount = allRequests.Count(r => r.Status == "Completed");

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error retrieving requests for admin: {ex.Message}");
        }
    }

    private void NavigateToManageRequests()
    {
        Navigation.NavigateTo("/admin/requests");
    }

    private void OpenReviewModal(RequestItem request)
    {
        selectedRequest = request;
        showReviewModal = true;
    }

    private async Task CloseReviewModal()
    {
        showReviewModal = false;
        selectedRequest = null;
        await RefreshData(); // Instantly refresh statistics counts if a request status changed
    }

    private string GetStatusBadgeClass(string status) => status switch
    {
        "Pending" => "bg-amber-50 text-amber-700 border border-amber-200",
        "In Progress" or "Processing" => "bg-purple-50 text-purple-700 border border-purple-200",
        "Ready for Pickup" => "bg-green-50 text-green-700 border border-green-200",
        "Completed" => "bg-blue-50 text-blue-700 border border-blue-200",
        _ => "bg-slate-50 text-slate-700"
    };

    private string GetStatusDotClass(string status) => status switch
    {
        "Pending" => "bg-amber-500",
        "In Progress" or "Processing" => "bg-purple-500",
        "Ready for Pickup" => "bg-green-500",
        "Completed" => "bg-blue-500",
        _ => "bg-slate-500"
    };
}
