@page "/user/requests"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@using gov_connect.Components.Shared

<PageTitle>My Requests | GovConnect</PageTitle>

<div class="requests-page">
    <header class="requests-page-heading">
        <div><p class="section-label">Citizen Applications</p><h1>My Requests</h1><p>Manage and monitor all your document requests and appointments.</p></div>
        <button class="new-request-button" @onclick='() => Navigation.NavigateTo("/user/services")'><span aria-hidden="true">+</span> Start a new request</button>
    </header>

    <nav class="request-tabs" aria-label="Filter requests by status">
        @foreach (var tab in tabs)
        {
            <button class="@(activeTab == tab ? "active" : "")" @onclick="() => activeTab = tab">@tab <span>@GetTabCount(tab)</span></button>
        }
    </nav>

    <div class="request-list" aria-live="polite">
        @foreach (var request in FilteredRequests)
        {
            <article class="request-list-card">
                <div class="request-card-main">
                    <AgencyBadge Agency="@request.Agency" />
                    <div class="request-card-copy">
                        <div class="request-title-row"><div><h2>@request.Document</h2><p>@request.AgencyName</p></div><span class="request-status-tag status-@request.Status.ToLowerInvariant()">@request.Status</span></div>
                        <dl><div><dt>Reference number</dt><dd>@request.Reference</dd></div><div><dt>Submitted</dt><dd>@request.Submitted</dd></div><div><dt>Service type</dt><dd>@request.ServiceType</dd></div></dl>
                    </div>
                </div>
                <div class="request-card-progress">
                    <div><span>Application progress</span><strong>@request.Progress%</strong></div>
                    <div class="request-list-progress"><span style="width: @request.Progress%"></span></div>
                    <p>@request.NextStep</p>
                </div>
                <div class="request-card-actions"><button @onclick="() => Track(request.Reference)"><span aria-hidden="true">⌕</span> Track request</button></div>
            </article>
        }
        @if (!FilteredRequests.Any())
        {
            <div class="requests-empty"><strong>No @activeTab.ToLowerInvariant() requests</strong><p>Your requests with this status will appear here.</p></div>
        }
    </div>
</div>

@code {
    private string activeTab = "All";
    private readonly string[] tabs = ["All", "Pending", "Processing", "Ready", "Completed"];
    private readonly RequestSummary[] requests =
    [
        new("GC-2025-001235", "Birth Certificate", "PSA", "Philippine Statistics Authority", "Ready", 100, "12 December 2025", "Online request", "Ready for pickup at the PSA Main Office."),
        new("GC-2025-001198", "Philippine Passport", "DFA", "Department of Foreign Affairs", "Processing", 45, "10 December 2025", "Appointment", "Application is undergoing identity verification."),
        new("GC-2025-001174", "National ID", "PhilSys", "Philippine Identification System", "Pending", 15, "9 December 2025", "Appointment", "Waiting for your scheduled biometric appointment."),
        new("GC-2025-001106", "NBI Clearance", "NBI", "National Bureau of Investigation", "Completed", 100, "2 December 2025", "Appointment", "Request completed and released.")
    ];
    private IEnumerable<RequestSummary> FilteredRequests => activeTab == "All" ? requests : requests.Where(r => r.Status == activeTab);
    private int GetTabCount(string tab) => tab == "All" ? requests.Length : requests.Count(r => r.Status == tab);
    private void Track(string reference) => Navigation.NavigateTo($"/user/track?reference={Uri.EscapeDataString(reference)}");
    private sealed record RequestSummary(string Reference, string Document, string Agency, string AgencyName, string Status, int Progress, string Submitted, string ServiceType, string NextStep);
}
