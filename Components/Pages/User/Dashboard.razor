@page "/user/dashboard"
@inject Supabase.Client SupabaseClient
@inject NavigationManager Navigation
@using gov_connect.Components.Shared

<div class="citizen-dashboard">
    <div class="dashboard-heading">
        <div>
            <p class="dashboard-eyebrow">Citizen Service Dashboard</p>
            <h1>Citizen Dashboard</h1>
            <p>Manage document applications and monitor requests across participating government agencies.</p>
        </div>
    </div>

    <section class="dashboard-actions" aria-label="Primary actions">
        <div class="dashboard-actions-copy">
            <span class="section-label">GovConnect Online Services</span>
            <h2>Magandang Umaga, @(string.IsNullOrEmpty(firstName) ? "Citizen" : firstName)!</h2>
            <p>Access government services in one place. Submit requirements online and track every application through your citizen account.</p>
        </div>
        <div class="dashboard-action-buttons">
            <button class="primary-gov-button" @onclick="NavigateToServices">
                <img src="/icons/add.svg" alt="" aria-hidden="true" />
                Start a new request
            </button>
            <NavLink href="/user/track" class="secondary-gov-button">
                <img src="/icons/search.svg" alt="" aria-hidden="true" />
                Track an existing request
            </NavLink>
        </div>
    </section>

    <section aria-labelledby="request-overview-title">
        <div class="section-heading-row">
            <div><p class="section-label">Request Overview</p><h2 id="request-overview-title">Application summary</h2></div>
            <NavLink href="/user/requests" class="text-link">View all requests <span aria-hidden="true">→</span></NavLink>
        </div>
        <div class="metrics-grid">
            <NavLink href="/user/requests" class="metric-card">
                <div class="metric-icon"><img src="/icons/total-requests.svg" alt="" /></div>
                <div><span>All requests</span><strong>24</strong><small>Across all agencies</small></div>
            </NavLink>
            <div class="metric-card">
                <div class="metric-icon"><img src="/icons/for-pickup.svg" alt="" /></div>
                <div><span>In progress</span><strong>3</strong><small>Currently being processed</small></div>
            </div>
            <div class="metric-card metric-ready">
                <div class="metric-icon"><img src="/icons/in-progress.svg" alt="" /></div>
                <div><span>Ready for release</span><strong>9</strong><small>Available for pickup</small></div>
            </div>
        </div>
    </section>

    <div class="dashboard-content-grid">
        <section class="dashboard-panel" aria-labelledby="recent-title">
            <div class="panel-heading"><div><p class="section-label">Recent Activity</p><h2 id="recent-title">Latest request</h2></div><span class="request-status">Processing</span></div>
            <div class="request-record">
                <div class="record-icon"><img src="/icons/birth-certificate.svg" alt="" /></div>
                <div class="record-main">
                    <h3>Birth Certificate</h3>
                    <p>Philippine Statistics Authority</p>
                    <dl><div><dt>Reference number</dt><dd>GC-35356-5436</dd></div><div><dt>Date submitted</dt><dd>09 December 2025</dd></div></dl>
                </div>
            </div>
            <div class="request-progress">
                <div><span>Application progress</span><strong>75%</strong></div>
                <div class="progress-track"><span style="width: 75%"></span></div>
                <p>Your request is being verified by the issuing agency.</p>
            </div>
            <NavLink href="/user/requests" class="panel-link">View request details <span aria-hidden="true">→</span></NavLink>
        </section>

        <aside class="dashboard-panel service-guide" aria-labelledby="guide-title">
            <div class="panel-heading"><div><p class="section-label">Citizen Guide</p><h2 id="guide-title">Before you apply</h2></div></div>
            <ol>
                <li><span>1</span><div><strong>Select a document</strong><small>Choose from supported agency services.</small></div></li>
                <li><span>2</span><div><strong>Submit requirements</strong><small>Provide complete and accurate information.</small></div></li>
                <li><span>3</span><div><strong>Track your request</strong><small>Monitor verification through your account.</small></div></li>
            </ol>
            <p class="security-note"><strong>Secure transactions</strong><br />Your personal information is protected throughout the request process.</p>
        </aside>
    </div>

    <section aria-labelledby="services-title">
        <div class="section-heading-row">
            <div><p class="section-label">Participating Agencies</p><h2 id="services-title">Frequently requested services</h2></div>
            <NavLink href="/user/services" class="text-link">Browse all services <span aria-hidden="true">→</span></NavLink>
        </div>
        <div class="services-grid">
            <button class="service-card" @onclick='() => RequestDoc("birth-certificate")'><AgencyBadge Agency="PSA" /><span><strong>Birth Certificate</strong><small>Philippine Statistics Authority</small></span><b class="agency-tag agency-tag-psa">PSA</b></button>
            <button class="service-card" @onclick='() => RequestDoc("national-id")'><AgencyBadge Agency="PhilSys" /><span><strong>National ID</strong><small>Philippine Identification System</small></span><b class="agency-tag agency-tag-philsys">PhilSys</b></button>
            <button class="service-card" @onclick='() => RequestDoc("drivers-license")'><AgencyBadge Agency="LTO" /><span><strong>Driver's License</strong><small>Land Transportation Office</small></span><b class="agency-tag agency-tag-lto">LTO</b></button>
            <button class="service-card" @onclick='() => RequestDoc("philippine-passport")'><AgencyBadge Agency="DFA" /><span><strong>Philippine Passport</strong><small>Department of Foreign Affairs</small></span><b class="agency-tag agency-tag-dfa">DFA</b></button>
        </div>
    </section>
</div>

@code {
    private string firstName = "User";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var user = SupabaseClient.Auth.CurrentUser;
            if (user != null && user.UserMetadata != null)
            {
                if (user.UserMetadata.TryGetValue("full_name", out var nameObj) && nameObj != null)
                {
                    string fullName = nameObj.ToString() ?? string.Empty;

                    var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                    if (nameParts.Length > 0)
                    {
                        firstName = nameParts[0];
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error obtaining user session details: {ex.Message}");
        }
    }

    private void NavigateToServices()
    {
        Navigation.NavigateTo("/user/services");
    }

    private void RequestDoc(string slug)
    {
        Navigation.NavigateTo($"/user/request/{slug}");
    }
}
