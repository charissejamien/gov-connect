@page "/notfound"

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
    <h1 class="text-6xl font-extrabold text-slate-900 mb-2">404</h1>
    <h2 class="text-2xl font-bold text-slate-700 mb-4">Page Not Found</h2>
    <p class="text-slate-500 max-w-md mb-8">
        The government document system page you are looking for does not exist or has been moved.
    </p>
    <a href="user/dashboard"
       class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2.5 px-5 rounded-lg shadow transition-colors">
        Go Back Home
    </a>
</div>