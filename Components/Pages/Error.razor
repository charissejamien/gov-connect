@page "/Error"
@using System.Diagnostics

<PageTitle>Service Error | GovConnect</PageTitle>
<div class="system-state-page error-state">
    <div class="system-state-code">!</div>
    <p class="section-label">Service Interruption</p>
    <h1>We could not complete your request.</h1>
    <p>Please try again in a few moments. Your information has not been submitted twice.</p>
    @if (ShowRequestId)
    {
        <p class="request-id"><strong>Support reference:</strong> <code>@RequestId</code></p>
    }
    <NavLink href="/user/dashboard" class="system-state-action">Return to dashboard</NavLink>
</div>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }
    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);
    protected override void OnInitialized() => RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
