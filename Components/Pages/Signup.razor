@page "/signup"
@layout Components.Layout.AuthLayout
@rendermode InteractiveServer
@inject Supabase.Client SupabaseClient
@inject NavigationManager Navigation

<div class="min-h-screen w-full flex flex-col justify-center items-center px-4 bg-cover bg-no-repeat bg-center"
     style="background-image: url('icons/authentication-bg.svg');">

    <div
        class="w-full max-w-md bg-white border border-slate-200 border-t-[9px] border-t-[#FFC456] shadow-xl rounded-2xl p-10 flex flex-col items-center gap-6">

        <div class="flex flex-col items-center text-center">
            <img src="icons/authentication.svg" alt="Auth Icon" class="w-12 h-12 mb-2">
            <h2 class="text-[28px] font-semibold">Create Account</h2>
            <p class="text-[14px] font-medium text-gray-500">Join us today - it's free</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="w-full bg-red-50 border border-red-200 text-red-600 text-[14px] px-4 py-3 rounded-xl font-medium">
                @errorMessage
            </div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div
                class="w-full bg-green-50 border border-green-200 text-green-600 text-[14px] px-4 py-3 rounded-xl font-medium">
                @successMessage
            </div>
        }

        <EditForm Model="@signUpModel" OnValidSubmit="HandleSignUp" class="w-full flex flex-col gap-4">

            <div class="w-full flex flex-col gap-1.5">
                <label class="text-[14px] font-semibold text-slate-700 tracking-wide">Full Name</label>
                <input type="text" @bind="signUpModel.FullName" required
                       class="w-full border border-slate-200 rounded-xl px-4 py-2.5 bg-gray-50/50 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">
            </div>

            <div class="w-full flex flex-col gap-1.5">
                <label class="text-[14px] font-semibold text-slate-700 tracking-wide">Email Address</label>
                <input type="email" @bind="signUpModel.Email" required
                       class="w-full border border-slate-200 rounded-xl px-4 py-2.5 bg-gray-50/50 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">
            </div>

            <div class="w-full flex flex-col gap-1.5 relative">
                <label class="text-[14px] font-semibold text-slate-700 tracking-wide">Password</label>
                <div class="relative w-full">
                    <input type="@(showPassword ? "text" : "password")" @bind="signUpModel.Password" required
                           class="w-full border border-slate-200 rounded-xl pl-4 pr-11 py-2.5 bg-gray-50/50 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">

                    <button type="button" @onclick="TogglePassword"
                            class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-slate-400 hover:text-slate-600 transition-colors">
                        @if (showPassword)
                        {
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                            </svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <div class="w-full flex flex-col gap-1.5 relative">
                <label class="text-[14px] font-semibold text-slate-700 tracking-wide">Confirm Password</label>
                <div class="relative w-full">
                    <input type="@(showConfirmPassword ? "text" : "password")" @bind="signUpModel.ConfirmPassword"
                           required
                           class="w-full border border-slate-200 rounded-xl pl-4 pr-11 py-2.5 bg-gray-50/50 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all">

                    <button type="button" @onclick="ToggleConfirmPassword"
                            class="absolute inset-y-0 right-0 pr-3.5 flex items-center text-slate-400 hover:text-slate-600 transition-colors">
                        @if (showConfirmPassword)
                        {
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88" />
                            </svg>
                        }
                        else
                        {
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                      d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z" />
                                <circle cx="12" cy="12" r="3" />
                            </svg>
                        }
                    </button>
                </div>
            </div>

            <div class="w-full flex flex-col gap-5 mt-2">
                <button type="submit" disabled="@isSubmitting"
                        class="w-full bg-[#FFC456] hover:bg-[#e6b04d] transition-colors text-black font-semibold py-3 rounded-xl shadow-md hover:shadow-lg disabled:opacity-50">
                    @(isSubmitting ? "Creating Account..." : "Create Account")
                </button>

                <div class="relative flex py-1 items-center">
                    <div class="flex-grow border-t border-slate-100"></div>
                    <span class="flex-shrink mx-4 text-slate-400 text-[13px] font-normal bg-white px-2">or</span>
                    <div class="flex-grow border-t border-slate-100"></div>
                </div>

                <div class="text-center text-[14px] text-slate-600 font-medium">
                    Already have an account?
                    <NavLink href="login" class="text-blue-600 hover:underline ml-1 font-semibold">
                        Sign in
                    </NavLink>
                </div>
            </div>
        </EditForm>
    </div>
</div>

@code {
    private SignUpFormModel signUpModel = new();
    private string errorMessage = "";
    private string successMessage = "";
    private bool isSubmitting = false;
    private bool showPassword = false;
    private bool showConfirmPassword = false;

    private void TogglePassword() => showPassword = !showPassword;
    private void ToggleConfirmPassword() => showConfirmPassword = !showConfirmPassword;

    private async Task HandleSignUp()
    {
        errorMessage = "";
        successMessage = "";

        if (signUpModel.Password != signUpModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isSubmitting = true;

        try
        {
            var signUpOptions = new Supabase.Gotrue.SignUpOptions
            {
                Data = new Dictionary<string, object>
                {
                    { "full_name", signUpModel.FullName }
                }
            };

            var response = await SupabaseClient.Auth.SignUp(signUpModel.Email, signUpModel.Password, signUpOptions);

            if (response != null && response.User != null)
            {
                // FIX: Check response.AccessToken instead of response.Session
                if (string.IsNullOrEmpty(response.AccessToken))
                {
                    successMessage = "Account created! Please check your email to verify your registration.";
                }
                else
                {
                    successMessage = "Sign-up successful! Redirecting you to services...";
                    await Task.Delay(2000);
                    Navigation.NavigateTo("/user/services");
                }
            }
        }
        catch (Supabase.Gotrue.Exceptions.GotrueException ex)
        {
            errorMessage = ex.Message;
        }
        catch (Exception ex)
        {
            errorMessage = "An unexpected error occurred: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class SignUpFormModel
    {
        public string FullName { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}