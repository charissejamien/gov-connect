@page "/user/dashboard"

<div class="flex flex-col gap-10">
    <div class="mt-10 bg-[#400000] rounded-xl p-10 text-white">
        <div class="flex flex-col gap-5">
            <h1 class="text-[24px] font-semibold">Magandang Umaga, Maria!</h1>
            <p>Access all government services in one place. No more long queues,
                no more multiple trips to different cities.
            </p>
            <div class="flex gap-5">
                <button class="bg-[#276FC2] rounded-xl px-4 py-2">Request a Document</button>
                <button class="bg-[#D89843] rounded-xl px-4 py-2">Track a Request</button>
            </div>
        </div>
    </div>

    <div class="w-full flex gap-10">
        <div class="bg-[#D9D7E3] rounded-xl p-3 pb-7 w-full">
            <div>
                <p class="text-[12px]">Total Request</p>
            </div>
            <h2 class="font-semibold text-[18px] mt-1">24</h2>
        </div>
        <div class="bg-[#D9D7E3] rounded-xl p-3 pb-7 w-full">
            <div>
                <p class="text-[12px]">In Progress</p>
            </div>
            <h2 class="font-semibold text-[18px] mt-1">3</h2>
        </div>
        <div class="bg-[#D9D7E3] rounded-xl p-3 pb-7 w-full">
            <div>
                <p class="text-[12px]">Ready for Pickup</p>
            </div>
            <h2 class="font-semibold text-[18px] mt-1">9</h2>
        </div>
    </div>

    <div>
        <h3 class="text-[28px] font-semibold">Quick Services</h3>
        <div class="bg-[#E8E6F4] rounded-xl p-3 pb-7 w-full">
            <h2>Birth Certificate</h2>
            <p>PSA</p>
        </div>
    </div>
</div>



