@page "/user/request/{DocumentSlug}"
@rendermode InteractiveServer

@using gov_connect.Data
@using gov_connect.Data.Models
@using gov_connect.Data.Services
@inject Supabase.Client SupabaseClient
@inject NavigationManager Navigation

<div class="min-h-screen bg-[#F0F2F9] py-12 px-4 md:px-8 font-sans">
    <div class="max-w-3xl mx-auto bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-gray-100">

        <h2 class="text-3xl font-bold text-center text-gray-900 mb-8">Government Services</h2>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="mb-6 bg-red-50 border border-red-200 text-red-600 text-sm px-4 py-3 rounded-xl font-medium">
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="mb-6 bg-green-50 border border-green-200 text-green-600 text-sm px-4 py-3 rounded-xl font-medium">
                @successMessage
            </div>
        }

        <EditForm Model="@requestModel" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="space-y-6">

                <div>
                    <label class="block text-gray-600 text-sm font-semibold mb-2">Document Type *</label>
                    <input type="text" value="@MatchedDocument?.Title" disabled
                           class="w-full px-4 py-3 bg-[#F6F6F6] text-gray-700 rounded-xl border border-gray-200 focus:outline-none cursor-not-allowed font-medium" />
                </div>

                <div>
                    <label class="block text-gray-600 text-sm font-semibold mb-2">Purpose of Request *</label>
                    <select @bind="requestModel.Purpose" required
                            class="w-full px-4 py-3 bg-[#F6F6F6] text-gray-700 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer">
                        <option value="">Select Purpose</option>
                        <option value="Employment">Employment</option>
                        <option value="Identification">Identification/ID Application</option>
                        <option value="Travel">Travel / Passport Application</option>
                        <option value="Personal">Personal Use</option>
                    </select>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-gray-600 text-sm font-semibold mb-2">First Name *</label>
                        <input type="text" @bind="requestModel.FirstName" placeholder="Enter first name" required
                               class="w-full px-4 py-3 bg-[#F6F6F6] text-gray-700 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                    <div>
                        <label class="block text-gray-600 text-sm font-semibold mb-2">Middle Name</label>
                        <input type="text" @bind="requestModel.MiddleName" placeholder="Enter middle name"
                               class="w-full px-4 py-3 bg-[#F6F6F6] text-gray-700 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                </div>

                <div>
                    <label class="block text-gray-600 text-sm font-semibold mb-2">Last Name *</label>
                    <input type="text" @bind="requestModel.LastName" placeholder="Enter last name" required
                           class="w-full px-4 py-3 bg-[#F6F6F6] text-gray-700 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>

                <div>
                    <label class="block text-gray-600 text-sm font-semibold mb-3">Delivery Method *</label>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

                        <label
                            class="flex items-center gap-3 p-4 bg-[#F6F6F6] rounded-xl border border-gray-200 cursor-pointer transition-all hover:bg-gray-100">
                            <input type="radio" name="delivery" value="PickUp"
                                   checked="@(requestModel.DeliveryMethod == "PickUp")"
                                   @onchange="@(() => requestModel.DeliveryMethod = "PickUp")"
                                   class="w-4 h-4 text-blue-600 focus:ring-blue-500 border-gray-300" />
                            <span class="text-gray-800 font-medium">Pick Up</span>
                        </label>

                        <label
                            class="flex items-center gap-3 p-4 bg-[#F6F6F6] rounded-xl border border-gray-200 cursor-pointer transition-all hover:bg-gray-100">
                            <input type="radio" name="delivery" value="Delivery"
                                   checked="@(requestModel.DeliveryMethod == "Delivery")"
                                   @onchange="@(() => requestModel.DeliveryMethod = "Delivery")"
                                   class="w-4 h-4 text-blue-600 focus:ring-blue-500 border-gray-300" />
                            <span class="text-gray-800 font-medium">Delivery</span>
                        </label>

                        <label
                            class="flex items-center gap-3 p-4 bg-[#F6F6F6] rounded-xl border border-gray-200 cursor-pointer transition-all hover:bg-gray-100">
                            <input type="radio" name="delivery" value="Ecopy"
                                   checked="@(requestModel.DeliveryMethod == "Ecopy")"
                                   @onchange="@(() => requestModel.DeliveryMethod = "Ecopy")"
                                   class="w-4 h-4 text-blue-600 focus:ring-blue-500 border-gray-300" />
                            <span class="text-gray-800 font-medium">Ecopy</span>
                        </label>

                    </div>
                </div>

                @if (requestModel.DeliveryMethod == "Delivery")
                {
                    <div class="transition-all duration-300">
                        <label class="block text-gray-600 text-sm font-semibold mb-2">Address (if delivery)</label>
                        <input type="text" @bind="requestModel.Address" placeholder="Complete address delivery" required
                               class="w-full px-4 py-3 bg-[#F6F6F6] text-gray-700 rounded-xl border border-gray-200 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                    </div>
                }

                <div
                    class="bg-[#D3E3FD] text-[#0A1D37] p-5 rounded-2xl flex items-start gap-3.5 border border-[#A8C7FA]">
                    <svg class="w-6 h-6 text-[#002D62] shrink-0 mt-0.5" fill="none" stroke="currentColor"
                         stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round"
                              d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <div>
                        <p class="font-bold text-[15px] mb-1">You will need to upload</p>
                        <ul class="list-disc list-inside text-xs space-y-1 opacity-90">
                            <li>Valid Government ID (front and back)</li>
                            <li>1x1 or 2x2 Photo (white background)</li>
                            <li>Supporting documents (if applicable)</li>
                        </ul>
                    </div>
                </div>

                <div>
                    <label class="block text-gray-600 text-sm font-semibold mb-2">Required Documents</label>
                    <div
                        class="border-2 border-dashed border-gray-300 rounded-2xl p-8 flex flex-col items-center justify-center bg-[#FAFBFD] hover:bg-gray-50 transition-colors cursor-pointer">
                        <svg class="w-10 h-10 text-gray-400 mb-3" fill="none" stroke="currentColor" stroke-width="1.5"
                             viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round"
                                  d="M12 16.5V9.75m0 0l3 3m-3-3l-3 3M6.75 19.5a4.5 4.5 0 01-1.41-8.775 5.25 5.25 0 0110.233-2.33 3 3 0 013.758 3.848A3.752 3.752 0 0118 19.5H6.75z">
                            </path>
                        </svg>
                        <p class="text-gray-600 text-sm text-center">Choose a file or drag & drop it here</p>
                        <button type="button"
                                class="mt-3 px-5 py-2 bg-white border border-gray-300 rounded-lg text-sm text-gray-700 font-semibold shadow-sm hover:bg-gray-50">
                            Browse File
                        </button>
                    </div>
                </div>

                <div class="pt-4">
                    <button type="submit" disabled="@isSubmitting"
                            class="w-full bg-[#1A73E8] hover:bg-blue-600 text-white font-semibold py-3.5 px-6 rounded-xl text-center transition-colors duration-150 disabled:opacity-50">
                        @(isSubmitting ? "Submitting..." : "Request")
                    </button>
                </div>

            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter]
    public string DocumentSlug { get; set; } = "";

    private DocumentItem? MatchedDocument { get; set; }
    private RequestFormModel requestModel = new();
    private bool isSubmitting = false;
    private string errorMessage = "";
    private string successMessage = "";

    protected override void OnParametersSet()
    {
        MatchedDocument = DocumentData.Documents
            .FirstOrDefault(d => d.Slug.Equals(DocumentSlug, StringComparison.OrdinalIgnoreCase));

        if (MatchedDocument == null)
        {
            Navigation.NavigateTo("/user/services");
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = "";
        successMessage = "";

        var currentUser = SupabaseClient.Auth.CurrentUser;
        if (currentUser == null)
        {
            errorMessage = "You must be signed in to submit a request.";
            return;
        }

        if (MatchedDocument == null)
        {
            errorMessage = "Invalid document mapping error.";
            return;
        }

        if (requestModel.DeliveryMethod == "Delivery" && string.IsNullOrWhiteSpace(requestModel.Address))
        {
            errorMessage = "Please enter a delivery address.";
            return;
        }

        isSubmitting = true;

        try
        {
            var newRequest = new RequestItem
            {
                UserId = currentUser.Id,
                DocumentTitle = MatchedDocument.Title,
                DocumentAgency = MatchedDocument.Agency,
                Purpose = requestModel.Purpose,
                FirstName = requestModel.FirstName,
                MiddleName = requestModel.MiddleName,
                LastName = requestModel.LastName,
                DeliveryMethod = requestModel.DeliveryMethod,
                Address = requestModel.DeliveryMethod == "Delivery" ? requestModel.Address : null,
                Status = "Pending",
                CreatedAt = DateTime.UtcNow
            };

            await SupabaseClient.From<RequestItem>().Insert(newRequest);

            successMessage = "Your document request has been submitted successfully!";

            await Task.Delay(2000);
            Navigation.NavigateTo("/user/dashboard");
        }
        catch (Exception ex)
        {
            errorMessage = $"Submission failed: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class RequestFormModel
    {
        public string Purpose { get; set; } = "";
        public string FirstName { get; set; } = "";
        public string MiddleName { get; set; } = "";
        public string LastName { get; set; } = "";
        public string DeliveryMethod { get; set; } = "PickUp";
        public string Address { get; set; } = "";
    }
}